{{>header}}

{{>navbar}}

<div class="container my-3">
    <h2 class ="bg-secondary text-center p-2 text-light">Employee Records</h2>
    <div class="table-responsive">
    <table class="table table-bordered table-striped table-hover" id="mytable">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Designation</th>
                <th>Salary</th>
                <th>City</th>
                <th>State</th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {{#each data}}
            <tr>
                <td>{{_id}}</td>
                <td>{{name}}</td>
                <td>{{email}}</td>
                <td>{{phone}}</td>
                <td>{{designation}}</td>
                <td>{{salary}}</td>
                <td>{{city}}</td>
                <td>{{state}}</td>
                <td>
                    <a href="/edit/{{_id}}" class="btn btn-sm btn-primary">Edit</a>
                    
                </td>
                <td>
                    <a href="/delete/{{_id}}" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    </div>
</div>

{{>footer}}